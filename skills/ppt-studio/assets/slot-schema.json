{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PPT Studio Slot Schema",
  "type": "object",
  "properties": {
    "template_id": {"type": "string"},
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slide_key": {"type": "string"},
          "slide_number": {"type": "integer"},
          "role": {"type": "string"},
          "slots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slot_key": {"type": "string"},
                "semantic_type": {"type": "string"},
                "required": {"type": "boolean"},
                "cardinality": {"type": "string", "enum": ["one", "many"]},
                "shape_name": {"type": "string"},
                "shape_id": {"type": ["integer", "null"]},
                "render_rules": {"type": "object"}
              },
              "required": ["slot_key", "semantic_type", "required", "cardinality"]
            }
          }
        },
        "required": ["slide_key", "slide_number", "role", "slots"]
      }
    }
  },
  "required": ["template_id", "slides"]
}
